# ── Bot ──────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here
BOT_ADMIN_IDS=123456789,987654321

# ── Mode ─────────────────────────────────────────────────
# Set to true in production (webhook), false for local dev (polling)
USE_WEBHOOK=false
WEBHOOK_BASE_URL=https://yourdomain.com
WEBHOOK_SECRET=generate-a-random-secret-here
PORT=8000

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/botdb

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── OpenAI (optional) ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Dev ──────────────────────────────────────────────────
DEBUG=false
